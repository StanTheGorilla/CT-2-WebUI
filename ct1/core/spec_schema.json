{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["page_title", "color_theme", "layout_order", "components"],
  "properties": {
    "page_title": { "type": "string" },
    "color_theme": {
      "type": "object",
      "required": ["primary", "secondary", "accent", "background", "text"],
      "properties": {
        "primary":    { "type": "string", "pattern": "^([a-z]+(-[0-9]{2,3})?|#[0-9a-fA-F]{3,8})$" },
        "secondary":  { "type": "string", "pattern": "^([a-z]+(-[0-9]{2,3})?|#[0-9a-fA-F]{3,8})$" },
        "accent":     { "type": "string", "pattern": "^([a-z]+(-[0-9]{2,3})?|#[0-9a-fA-F]{3,8})$" },
        "background": { "type": "string", "pattern": "^([a-z]+(-[0-9]{2,3})?|#[0-9a-fA-F]{3,8})$" },
        "text":       { "type": "string", "pattern": "^([a-z]+(-[0-9]{2,3})?|#[0-9a-fA-F]{3,8})$" }
      }
    },
    "layout_order": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "required_elements", "content", "style_hints"],
        "properties": {
          "id":       { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "type":     { "enum": ["navbar", "hero", "features", "testimonials", "cta", "pricing", "contact", "footer", "gallery", "stats", "team", "faq", "custom"] },
          "required_elements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["tag", "identifier"],
              "properties": {
                "tag":        { "type": "string" },
                "identifier": { "type": "string" },
                "text":       { "type": "string" }
              }
            }
          },
          "content": {
            "type": "object",
            "properties": {
              "heading":     { "type": "string" },
              "subheading":  { "type": "string" },
              "body":        { "type": "string" },
              "items":       { "type": "array", "items": { "type": "object" } },
              "cta_text":    { "type": "string" },
              "cta_href":    { "type": "string" }
            }
          },
          "style_hints": { "type": "string" },
          "interactions": {
            "type": "array",
            "items": {
              "enum": ["hamburger-toggle", "smooth-scroll", "accordion", "form-validation", "dark-mode-toggle", "carousel", "modal", "scroll-reveal"]
            },
            "default": []
          }
        }
      }
    }
  }
}
